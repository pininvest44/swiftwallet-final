<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bulk STK Push Portal</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <h2>Bulk STK Push Panel</h2>
        <form action="/initiate-bulk" method="POST">
            <div class="form-group">
                <label for="phone_numbers">Phone Numbers (One per line):</label>
                <textarea id="phone_numbers" name="phone_numbers" rows="6" placeholder="254798765432&#10;254712345678" required></textarea>
            </div>
            
            <div class="form-row">
                <div class="form-group">
                    <label for="amount">Amount (KES):</label>
                    <input type="number" id="amount" name="amount" placeholder="1500" required>
                </div>
                <div class="form-group">
                    <label for="reference">Base Reference:</label>
                    <input type="text" id="reference" name="reference" placeholder="ORD-BULK" required>
                </div>
            </div>

            <div class="form-group">
                <label for="customer_name">Default Customer Name:</label>
                <input type="text" id="customer_name" name="customer_name" value="Jane Doe">
            </div>

            <button type="submit">Launch Bulk STK Process</button>
        </form>

        <hr>

        <h3>Live Execution Logs (Auto-refreshing)</h3>
        <div class="log-container" id="log-box">
            <p>Loading status logs...</p>
        </div>
    </div>

    <script>
        // Poll backend logs every 2 seconds to see progress live
        async function fetchLogs() {
            try {
                const res = await fetch('/api/logs');
                const logs = await res.json();
                const logBox = document.getElementById('log-box');
                
                if(logs.length === 0) {
                    logBox.innerHTML = '<p style="color: #666;">No requests processed yet.</p>';
                    return;
                }

                logBox.innerHTML = logs.map(log => `
                    <div class="log-item ${log.status.toLowerCase()}">
                        <strong>[${log.timestamp}] ${log.phone}</strong> - 
                        <span class="badge">${log.status}</span>
                        <pre>${log.details}</pre>
                    </div>
                `).join('');
            } catch (e) {
                console.error("Error updating logs", e);
            }
        }
        setInterval(fetchLogs, 2000);
        fetchLogs();
    </script>
</body>
</html>
